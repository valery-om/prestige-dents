---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import clinic from '../data/clinic.json';
---

<BaseLayout
  title={`Лицензии и сертификаты — ${clinic.name}`}
  description={`Лицензия на осуществление медицинской деятельности ${clinic.license.number}. Сертификаты врачей стоматологии Престиж.`}
  breadcrumbs={[{ name: 'Лицензии', url: 'https://prestige-dents.ru/licenzii/' }]}
>
  <div style="max-width: 800px; margin: 0 auto; padding: 0 2rem;">
    <Breadcrumbs items={[{ name: 'Лицензии', url: '/licenzii/' }]} />
  </div>

  <!-- Hero -->
  <section style="background: var(--bg-alt); padding: 40px 0 50px;">
    <div style="max-width: 800px; margin: 0 auto; padding: 0 2rem;">
      <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.75rem; font-weight: 700;">
        Лицензии и сертификаты
        <span style="display: block; height: 4px; width: 64px; background: var(--color-brand); border-radius: 9999px; margin-top: 0.75rem;"></span>
      </h1>
    </div>
  </section>

  <section style="padding: 80px 0;">
    <div style="max-width: 800px; margin: 0 auto; padding: 0 2rem;">
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.75rem;">Лицензия на медицинскую деятельность</h2>
        <p style="margin-bottom: 0.25rem;"><strong>Номер:</strong> {clinic.license.number}</p>
        <p style="margin-bottom: 0.25rem;"><strong>Дата выдачи:</strong> {new Date(clinic.license.date).toLocaleDateString('ru-RU')}</p>
        <p style="margin-bottom: 0.25rem;"><strong>Выдана:</strong> {clinic.license.authority}</p>
        <p style="margin-bottom: 0.25rem;"><strong>Статус:</strong> действующая</p>
        <p style="margin-top: 0.75rem;"><strong>{clinic.legalName}</strong>, ИНН {clinic.inn}, ОГРН {clinic.ogrn}</p>
      </div>

      <p style="color: var(--text-muted);">
        Сканы лицензии и сертификатов врачей будут добавлены после получения от клиники.
      </p>
    </div>
  </section>
</BaseLayout>
