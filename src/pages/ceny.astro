---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout
  title="Цены на стоматологические услуги в Магнитогорске | Престиж"
  description="Актуальные цены на стоматологические услуги в Магнитогорске. Лечение, протезирование, имплантация, ортодонтия, гигиена. Стоматология Престиж."
  breadcrumbs={[{ name: 'Цены', url: 'https://prestige-dents.ru/ceny/' }]}
>
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
    <Breadcrumbs items={[{ name: 'Цены', url: '/ceny/' }]} />
  </div>

  <!-- Hero -->
  <section style="background: var(--bg-alt); padding: 40px 0 50px;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
      <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.75rem; font-weight: 700;">
        Цены
        <span style="display: block; height: 4px; width: 64px; background: var(--color-brand); border-radius: 9999px; margin-top: 0.75rem;"></span>
      </h1>
      <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 1rem; max-width: 640px;">
        Актуальные цены на услуги. Точную стоимость лечения врач определит после осмотра.
      </p>
    </div>
  </section>

  <section style="padding: 80px 0;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">

      <!-- Первичный приём -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;">Первичный приём</h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);">
              <th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th>
              <th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th>
            </tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Консультация терапевта</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Консультация пародонтолога</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 500 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Консультация хирурга</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Консультация ортопеда</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Повторный приём</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">250 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Терапия -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;"><a href="/uslugi/terapiya/" style="text-decoration: none; color: inherit;">Терапия</a></h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);"><th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th><th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th></tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Пломба Vitremer (до 1/3 зуба)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 200 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Пломба Vitremer (до 2/3 зуба)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 600 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Фотополимерная реставрация (до 1/3)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">от 5 800 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Фотополимерная реставрация (до 1/2)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">от 6 100 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Фотополимерная реставрация (более 1/2)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">от 6 400 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Протезирование -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;"><a href="/uslugi/protezirovanie/" style="text-decoration: none; color: inherit;">Протезирование</a></h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);"><th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th><th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th></tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Временная коронка</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 100 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Металлокерамика (класс B)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">9 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Металлокерамика (класс A)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">12 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Диоксид циркония (ZrO₂)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">19 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Безметалловая E-max</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">21 500 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Частичный протез (1–3 зуба)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">12 600 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Частичный протез (4–9 зубов)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">20 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Полный протез (10–14 зубов)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">28 400 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Бюгельный односторонний</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">31 500 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Бюгельный двусторонний</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">33 600 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Имплантация -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;"><a href="/uslugi/implantaciya/" style="text-decoration: none; color: inherit;">Имплантация</a></h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);"><th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th><th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th></tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Any One / Super Line</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">36 500 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Nobel / Straumann / Astra Tech</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">63 000 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Ортодонтия -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;"><a href="/uslugi/ortodontiya/" style="text-decoration: none; color: inherit;">Ортодонтия</a></h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);"><th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th><th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th></tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Лигатурные брекеты (2 челюсти)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">47 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Безлигатурные брекеты (2 челюсти)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">94 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Элайнеры SS IQ (до 10 шагов)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">105 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Элайнеры SS IQ (до 20 шагов)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">157 500 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Элайнеры SS IQ (до 36 шагов)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">204 500 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Элайнеры Kinder (до 7 шагов)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">84 000 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Гигиена -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;"><a href="/uslugi/gigiena-i-otbelivanie/" style="text-decoration: none; color: inherit;">Гигиена</a></h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);"><th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th><th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th></tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Подбор средств гигиены</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">350 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Чистка циркулярными щётками</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">4 200 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Чистка Air Flow</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">5 300 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Комплексная (УЗ + Air Flow + реминерализация)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">6 300 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Хирургия -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;"><a href="/uslugi/hirurgiya/" style="text-decoration: none; color: inherit;">Хирургия</a></h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);"><th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th><th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th></tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Удаление временного зуба</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Удаление подвижного зуба</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 000 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Удаление постоянного зуба</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 700 ₽</td></tr>
              <tr style="border-bottom: 1px solid var(--border); background: var(--bg-alt);"><td style="padding: 0.75rem 1rem;">Сложное удаление</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">3 500 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Диагностика -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;"><a href="/uslugi/diagnostika/" style="text-decoration: none; color: inherit;">Диагностика</a></h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);"><th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th><th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th></tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">КЛКТ (полная, без суставов)</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">3 100 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Пародонтология -->
      <div class="glass-card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;"><a href="/uslugi/parodontologiya/" style="text-decoration: none; color: inherit;">Пародонтология</a></h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse;">
            <thead><tr style="border-bottom: 1px solid var(--border);"><th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Услуга</th><th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.875rem; font-weight: 600;">Стоимость</th></tr></thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border);"><td style="padding: 0.75rem 1rem;">Первичный приём пародонтолога</td><td style="padding: 0.75rem 1rem; text-align: right; font-weight: 700; color: var(--color-brand);">1 500 ₽</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <p style="font-size: 0.875rem; color: var(--text-muted); margin-top: 0.5rem;">
        Указаны ориентировочные цены. Точную стоимость лечения врач определит после осмотра и диагностики.
        Полный прайс-лист доступен в клинике.
      </p>

      <div style="margin-top: 2rem; text-align: center;">
        <a href="/kontakty/#zapis" class="btn-cta">Записаться на приём</a>
      </div>
    </div>
  </section>
  <style is:inline>
    .glass-card > div[style*="overflow-x"] {
      -webkit-overflow-scrolling: touch;
    }
    @media (max-width: 640px) {
      .glass-card table td,
      .glass-card table th {
        padding: 0.5rem 0.5rem !important;
        font-size: 0.8rem !important;
      }
    }
  </style>
</BaseLayout>
