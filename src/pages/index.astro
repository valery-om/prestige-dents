---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import clinic from '../data/clinic.json';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const doctors = (await getCollection('doctors'))
  .filter(d => d.data.order <= 10)
  .sort((a, b) => a.data.order - b.data.order);

const serviceDescriptions: Record<string, string> = {
  terapiya: 'Лечение кариеса и пульпита. Безболезненная анестезия гелем.',
  protezirovanie: 'Коронки, виниры, съёмные протезы. Металлокерамика и цирконий.',
  implantaciya: 'Немецкие и швейцарские системы. AI-планирование лечения.',
  ortodontiya: 'Брекеты и прозрачные элайнеры для детей и взрослых.',
  'gigiena-i-otbelivanie': 'Air Flow, ультразвук, реминерализация.',
  hirurgiya: 'Простое и сложное удаление. Безболезненно.',
  diagnostika: '3D-снимки (КЛКТ) с AI-анализом Diagnocat.',
  parodontologiya: 'Лечение дёсен: пародонтит, гингивит.',
  'detskaya-stomatologiya': 'Молочные зубы, цветные пломбы. Без страха.',
};

function getInitials(name: string): string {
  const parts = name.split(' ');
  if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
  return parts[0][0].toUpperCase();
}
---

<BaseLayout>

  <!-- ===== HERO WITH VIDEO ===== -->
  <section style="position: relative; overflow: hidden; padding: 100px 0 120px; min-height: 500px;">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;"
    >
      <source src="/videos/promo.mp4" type="video/mp4" />
    </video>
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(60,164,203,0.75) 0%, rgba(42,143,181,0.8) 100%); z-index: 1;"></div>
    <div style="position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 0 2rem; text-align: center;">
      <h1 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 700; color: #fff; margin-bottom: 1.25rem; line-height: 1.2;">
        Семейная стоматология<br/>в Магнитогорске
      </h1>
      <p style="font-size: clamp(1.1rem, 2.5vw, 1.4rem); color: rgba(255,255,255,0.85); margin-bottom: 2.5rem; font-weight: 400;">
        Ваша улыбка — наш престиж
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/kontakty/#zapis" class="btn-cta" style="padding: 1rem 3rem; font-size: 1.1rem;">
          Записаться на приём
        </a>
        <a href={`tel:${clinic.phoneRaw}`} style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 1rem 2.5rem; background: rgba(255,255,255,0.15); color: #fff; font-weight: 500; font-size: 1.1rem; border-radius: 50px; border: 1px solid rgba(255,255,255,0.3); transition: all 0.2s; text-decoration: none;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          {clinic.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ===== USP STATS ===== -->
  <section style="padding: 80px 0;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;">
        <div style="text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--color-brand-pale); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="var(--color-brand)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div style="font-size: 2.5rem; font-weight: 700; color: var(--color-brand); margin-bottom: 0.5rem;">4.9</div>
          <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">Рейтинг в 2ГИС —<br/>лучший в городе</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--color-brand-pale); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5"><rect x="4" y="4" width="16" height="16" rx="3"/><circle cx="9" cy="10" r="1.5" fill="var(--color-brand)" stroke="none"/><circle cx="15" cy="10" r="1.5" fill="var(--color-brand)" stroke="none"/><path d="M9 15c1 1.5 5 1.5 6 0"/></svg>
          </div>
          <div style="font-size: 2.5rem; font-weight: 700; color: var(--color-brand); margin-bottom: 0.5rem;">AI</div>
          <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">Diagnocat + DianApp<br/>AI-диагностика</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--color-brand-pale); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5"><circle cx="9" cy="7" r="3"/><circle cx="17" cy="7" r="3"/><path d="M2 21v-2a5 5 0 015-5h4a5 5 0 015 5v2"/><path d="M17 10a5 5 0 013 4.5V21"/></svg>
          </div>
          <div style="font-size: 2.5rem; font-weight: 700; color: var(--color-brand); margin-bottom: 0.5rem;">14</div>
          <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">Врачей с опытом<br/>до 32 лет</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--color-brand-pale); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/><path d="M9 12l2 2 4-4" stroke-width="2"/></svg>
          </div>
          <div style="font-size: 2.5rem; font-weight: 700; color: var(--color-brand); margin-bottom: 0.5rem;">0</div>
          <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">Боли — анестезия<br/>гелем без уколов</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section style="padding: 80px 0; background: var(--bg-alt);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); text-align: center; margin-bottom: 0.75rem;">Наши услуги</h2>
      <p style="text-align: center; color: var(--text-muted); font-size: 1.1rem; margin-bottom: 4rem;">
        Полный спектр стоматологической помощи для всей семьи
      </p>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
        {services.map((service) => (
          <a href={`/uslugi/${service.data.slug}/`}
            class="card"
            style="display: block; text-decoration: none; color: inherit;">
            <h3 style="font-size: 1.15rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text);">
              {service.data.title}
            </h3>
            <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.6;">
              {serviceDescriptions[service.data.slug] || ''}
            </p>
            {service.data.priceFrom && (
              <p style="font-size: 0.95rem; font-weight: 600; color: var(--color-brand);">
                от {service.data.priceFrom.toLocaleString('ru-RU')} ₽
              </p>
            )}
          </a>
        ))}
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/ceny/" class="btn-outline">Полный прайс-лист</a>
      </div>
    </div>
  </section>

  <!-- ===== DOCTORS ===== -->
  <section style="padding: 80px 0;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); text-align: center; margin-bottom: 0.75rem;">Наши врачи</h2>
      <p style="text-align: center; color: var(--text-muted); font-size: 1.1rem; margin-bottom: 4rem;">
        Команда из 14 специалистов с опытом от 4 до 32 лет
      </p>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2.5rem;">
        {doctors.slice(0, 8).map((doctor) => (
          <a href={`/vrachi/${doctor.data.slug}/`} style="text-decoration: none; color: inherit; text-align: center; display: block;">
            <div style="width: 160px; height: 160px; border-radius: 50%; overflow: hidden; margin: 0 auto 1.25rem; border: 3px solid var(--color-brand-pale);">
              {doctor.data.photo ? (
                <img src={doctor.data.photo} alt={doctor.data.name}
                  style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
                  loading="lazy" />
              ) : (
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #3CA4CB, #1F7B9C); color: white; font-weight: 700; font-size: 2rem;">
                  {getInitials(doctor.data.name)}
                </div>
              )}
            </div>
            <p style="font-weight: 600; font-size: 1rem; margin-bottom: 0.25rem;">{doctor.data.name.split(' ').slice(0, 2).join(' ')}</p>
            <p style="font-size: 0.875rem; color: var(--text-muted);">{doctor.data.specialty}</p>
            {doctor.data.experience && (
              <p style="font-size: 0.8rem; color: var(--color-brand); margin-top: 0.25rem; font-weight: 500;">
                Стаж: {doctor.data.experience}
              </p>
            )}
          </a>
        ))}
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/vrachi/" class="btn-outline">Все врачи</a>
      </div>
    </div>
  </section>

  <!-- ===== WHY US ===== -->
  <section style="padding: 80px 0; background: var(--bg-alt);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); text-align: center; margin-bottom: 4rem;">Почему выбирают нас</h2>

      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.5rem;">
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="width: 64px; height: 64px; min-width: 64px; border-radius: 50%; background: var(--color-brand-pale); display: flex; align-items: center; justify-content: center;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5"><rect x="4" y="4" width="16" height="16" rx="3"/><circle cx="9" cy="10" r="1.5" fill="var(--color-brand)" stroke="none"/><circle cx="15" cy="10" r="1.5" fill="var(--color-brand)" stroke="none"/><path d="M9 15c1 1.5 5 1.5 6 0"/></svg>
          </div>
          <div>
            <h3 style="font-size: 1.15rem; font-weight: 600; margin-bottom: 0.5rem;">AI-диагностика</h3>
            <p style="color: var(--text-muted); line-height: 1.7; font-size: 0.95rem;">Diagnocat анализирует 3D-снимки за 5 минут. DianApp оценивает гигиену по фото.</p>
          </div>
        </div>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="width: 64px; height: 64px; min-width: 64px; border-radius: 50%; background: var(--color-brand-pale); display: flex; align-items: center; justify-content: center;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <div>
            <h3 style="font-size: 1.15rem; font-weight: 600; margin-bottom: 0.5rem;">Без боли и страха</h3>
            <p style="color: var(--text-muted); line-height: 1.7; font-size: 0.95rem;">Анестезия гелем — без уколов. Единственная клиника в Магнитогорске с такой технологией.</p>
          </div>
        </div>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="width: 64px; height: 64px; min-width: 64px; border-radius: 50%; background: var(--color-brand-pale); display: flex; align-items: center; justify-content: center;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
          </div>
          <div>
            <h3 style="font-size: 1.15rem; font-weight: 600; margin-bottom: 0.5rem;">Международный опыт</h3>
            <p style="color: var(--text-muted); line-height: 1.7; font-size: 0.95rem;">Два врача прошли стажировку в ведущих клиниках Израиля.</p>
          </div>
        </div>
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="width: 64px; height: 64px; min-width: 64px; border-radius: 50%; background: var(--color-brand-pale); display: flex; align-items: center; justify-content: center;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div>
            <h3 style="font-size: 1.15rem; font-weight: 600; margin-bottom: 0.5rem;">Для всей семьи</h3>
            <p style="color: var(--text-muted); line-height: 1.7; font-size: 0.95rem;">От детской стоматологии до протезирования. Один врач ведёт всю семью.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EQUIPMENT ===== -->
  <section style="padding: 80px 0;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); text-align: center; margin-bottom: 0.75rem;">Что это значит для вас</h2>
      <p style="text-align: center; color: var(--text-muted); font-size: 1.1rem; margin-bottom: 4rem;">
        Технологии, которые делают лечение точнее, быстрее и комфортнее
      </p>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">🔬</div>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">Лечение под микроскопом</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">Врач видит каналы зуба с многократным увеличением. Это значит точное лечение и максимальное сохранение здоровых тканей.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">⚡</div>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">Лазер вместо скальпеля</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">Лечение дёсен лазером: минимум боли, быстрое заживление, стерильность. Без разрезов и швов.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">📷</div>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">Слепки без дискомфорта</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">Цифровой 3D-сканер снимает слепки за пару минут — без неприятной массы во рту. Коронки и виниры садятся идеально.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">🧠</div>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">AI проверяет снимки</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">Нейросеть анализирует 3D-снимки и подсвечивает проблемы, которые легко пропустить глазом. Двойной контроль: врач + AI.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">📋</div>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">Снимок сразу на экране</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">Цифровой рентген: результат за секунды, а не за полчаса. 3D-снимок показывает зуб со всех сторон — врач видит полную картину до начала лечения.</p>
        </div>
        <div class="card" style="text-align: center; padding: 2rem 1.5rem;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">💨</div>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">Чистка без боли</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">Air Flow убирает налёт мягкой воздушно-порошковой струёй — без царапин и неприятных ощущений. Зубы гладкие и чистые сразу.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section style="padding: 80px 0; background: linear-gradient(135deg, #3CA4CB 0%, #2a8fb5 100%);">
    <div style="max-width: 700px; margin: 0 auto; padding: 0 2rem; text-align: center;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.25rem); color: #fff; margin-bottom: 1rem;">Запишитесь на приём</h2>
      <p style="font-size: 1.1rem; color: rgba(255,255,255,0.8); margin-bottom: 2.5rem;">
        Позвоните или напишите в WhatsApp — администратор подберёт удобное время
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href={`tel:${clinic.phoneRaw}`}
          style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 1rem 2.5rem; background: #fff; color: var(--color-brand-dark); font-weight: 600; font-size: 1.1rem; border-radius: 50px; text-decoration: none; transition: all 0.2s;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          {clinic.phone}
        </a>
