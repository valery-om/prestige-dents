---
---
<button
  id="accessibility-toggle"
  aria-label="Версия для слабовидящих"
  aria-expanded="false"
  aria-controls="accessibility-panel"
  class="text-xs font-medium px-3 py-1.5 rounded-lg border border-current hover:bg-brand-pale transition-colors whitespace-nowrap"
>
  <svg class="inline w-4 h-4 mr-1 -mt-0.5 a11y-keep" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
  </svg>
  <span class="accessibility-label">Для слабовидящих</span>
</button>

<script is:inline>
(function() {
  // ═══ Default settings ═══
  var DEFAULTS = {
    font: 'normal',
    colors: '',
    spacing: 'normal',
    line: 'normal',
    images: 'on',
    active: false
  };

  // ═══ Class maps ═══
  var CLASS_MAP = {
    font: { normal: 'a11y-font-normal', large: 'a11y-font-large', xlarge: 'a11y-font-xlarge' },
    colors: { white: 'a11y-colors-white', black: 'a11y-colors-black', blue: 'a11y-colors-blue' },
    spacing: { normal: 'a11y-spacing-normal', wide: 'a11y-spacing-wide' },
    line: { normal: 'a11y-line-normal', wide: 'a11y-line-wide' },
    images: { off: 'a11y-no-images' }
  };

  // ═══ State ═══
  var settings = loadSettings();

  function loadSettings() {
    try {
      var stored = localStorage.getItem('prestige-a11y');
      if (stored) {
        var parsed = JSON.parse(stored);
        // Merge with defaults for any missing keys
        for (var key in DEFAULTS) {
          if (!(key in parsed)) parsed[key] = DEFAULTS[key];
        }
        return parsed;
      }
    } catch(e) {}
    return JSON.parse(JSON.stringify(DEFAULTS));
  }

  function saveSettings() {
    try {
      localStorage.setItem('prestige-a11y', JSON.stringify(settings));
    } catch(e) {}
  }

  // ═══ Apply classes to body ═══
  function applySettings() {
    var body = document.body;

    // Remove all a11y classes
    var toRemove = [];
    body.classList.forEach(function(cls) {
      if (cls.indexOf('a11y-') === 0) toRemove.push(cls);
    });
    toRemove.forEach(function(cls) { body.classList.remove(cls); });

    // Remove old data-theme="accessible"
    if (document.documentElement.getAttribute('data-theme') === 'accessible') {
      var prev = localStorage.getItem('prestige-theme-before-accessible') || '';
      document.documentElement.setAttribute('data-theme', prev);
      localStorage.setItem('prestige-theme', prev);
      localStorage.removeItem('prestige-theme-before-accessible');
    }

    if (!settings.active) return;

    // Font size
    if (settings.font && settings.font !== 'normal') {
      var fontClass = CLASS_MAP.font[settings.font];
      if (fontClass) body.classList.add(fontClass);
    }

    // Colors
    if (settings.colors) {
      var colorClass = CLASS_MAP.colors[settings.colors];
      if (colorClass) body.classList.add(colorClass);
    }

    // Letter spacing
    if (settings.spacing && settings.spacing !== 'normal') {
      var spacingClass = CLASS_MAP.spacing[settings.spacing];
      if (spacingClass) body.classList.add(spacingClass);
    }

    // Line height
    if (settings.line && settings.line !== 'normal') {
      var lineClass = CLASS_MAP.line[settings.line];
      if (lineClass) body.classList.add(lineClass);
    }

    // Images
    if (settings.images === 'off') {
      body.classList.add('a11y-no-images');
    }
  }

  // ═══ Update button pressed states in panel ═══
  function updatePanelUI() {
    var panel = document.getElementById('accessibility-panel');
    if (!panel) return;

    var buttons = panel.querySelectorAll('.a11y-btn[data-a11y]');
    buttons.forEach(function(btn) {
      var group = btn.getAttribute('data-a11y');
      var value = btn.getAttribute('data-value');
      var current = settings[group] || '';

      // For colors: empty means none selected
      if (group === 'colors') {
        btn.setAttribute('aria-pressed', current === value ? 'true' : 'false');
      }
      // For images: 'on' is default
      else if (group === 'images') {
        btn.setAttribute('aria-pressed', current === value ? 'true' : 'false');
      }
      // For font, spacing, line: 'normal' is default
      else {
        btn.setAttribute('aria-pressed', current === value ? 'true' : 'false');
      }
    });
  }

  // ═══ Toggle panel visibility ═══
  function togglePanel() {
    var panel = document.getElementById('accessibility-panel');
    var btn = document.getElementById('accessibility-toggle');
    if (!panel || !btn) return;

    var label = btn.querySelector('.accessibility-label');
    var isHidden = panel.classList.contains('hidden');

    if (isHidden) {
      // Open panel — activate a11y mode
      panel.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      if (label) label.textContent = 'Обычная версия';
      settings.active = true;
      // Apply default white scheme if no colors set
      if (!settings.colors) {
        settings.colors = 'white';
      }
      applySettings();
      updatePanelUI();
      saveSettings();
    } else {
      // Close panel — deactivate a11y mode
      panel.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      if (label) label.textContent = 'Для слабовидящих';
      settings.active = false;
      applySettings();
      saveSettings();
    }
  }

  // ═══ Handle setting button clicks ═══
  function handleSettingClick(e) {
    var btn = e.target.closest('.a11y-btn[data-a11y]');
    if (!btn) return;

    var group = btn.getAttribute('data-a11y');
    var value = btn.getAttribute('data-value');

    settings[group] = value;
    applySettings();
    updatePanelUI();
    saveSettings();
  }

  // ═══ Handle reset ═══
  function handleReset() {
    settings.font = DEFAULTS.font;
    settings.colors = 'white';
    settings.spacing = DEFAULTS.spacing;
    settings.line = DEFAULTS.line;
    settings.images = DEFAULTS.images;
    // Keep active=true, just reset values
    applySettings();
    updatePanelUI();
    saveSettings();
  }

  // ═══ Initialize on DOM ready ═══
  function init() {
    var toggleBtn = document.getElementById('accessibility-toggle');
    var panel = document.getElementById('accessibility-panel');
    var resetBtn = document.getElementById('a11y-reset-btn');

    if (toggleBtn) {
      toggleBtn.addEventListener('click', togglePanel);
    }

    if (panel) {
      panel.addEventListener('click', function(e) {
        if (e.target.closest('.a11y-btn[data-a11y]')) {
          handleSettingClick(e);
        }
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener('click', handleReset);
    }

    // Clean up FOUC prevention attributes from <html>
    document.documentElement.removeAttribute('data-a11y-color');
    document.documentElement.classList.remove('a11y-preload');

    // Restore state from localStorage
    if (settings.active) {
      if (panel) {
        panel.classList.remove('hidden');
      }
      if (toggleBtn) {
        toggleBtn.setAttribute('aria-expanded', 'true');
        var label = toggleBtn.querySelector('.accessibility-label');
        if (label) label.textContent = 'Обычная версия';
      }
      applySettings();
      updatePanelUI();
    }
  }

  // Handle both fresh load and Astro page transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Also re-init on Astro page navigation (View Transitions)
  document.addEventListener('astro:page-load', init);
})();
</script>
